# Copiar a .env y completar. El .env NO se commitea.

NODE_ENV=production
PORT=3001

# Origenes permitidos para CORS (CSV). Dominio del frontend + dev local.
CORS_ORIGINS=https://loseucaliptus.zuzudev.pro,http://localhost:5173

# Secreto para firmar los JWT del admin. Generar uno largo y aleatorio:
#   openssl rand -base64 48
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# Webhook de n8n (se alcanza por host-gateway desde el container).
# Ajustar la ruta del webhook segun el workflow de n8n.
N8N_WEBHOOK_URL=http://host.docker.internal:5678/webhook/loseucaliptos-pedido
